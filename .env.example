# Servidor de LM Studio (Developer > Start Server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Modelo a usar como cerebro del agente (debe soportar tool calling)
MODEL_ID=gemma-4-e4b-uncensored-hauhaucs-aggressive-q8_k_p

# Búsqueda web: crea una cuenta gratis en https://tavily.com y pega tu clave aquí
TAVILY_API_KEY=

# Máximo de pasos (tool calls) por petición antes de que el agente se detenga
MAX_TURNS=25

# Truncado de salidas de herramientas (caracteres) para no desbordar el contexto
MAX_TOOL_OUTPUT=8000

# Timeout de comandos de shell en segundos
SHELL_TIMEOUT=120

# Pon 1 para que ejecute comandos de shell sin pedir confirmación (¡bajo tu riesgo!)
AUTO_APPROVE=0

# Modelo de embeddings local para semantic_search (ya lo tienes en LM Studio)
EMBEDDING_MODEL_ID=text-embedding-nomic-embed-text-v1.5

# Temperatura del modelo (vacío = la que tenga LM Studio; 0.2-0.4 va bien para código)
TEMPERATURE=

# Límite de tokens por respuesta del modelo (vacío = sin límite)
MAX_RESPONSE_TOKENS=

# Segundos de inactividad tras los que LM Studio descarga el modelo de RAM (vacío = 60 min)
LMSTUDIO_TTL=

# Pon 1 para ver los logs internos del SDK (depuración)
AGENT_DEBUG=0

# Directorio sobre el que trabaja el agente; por defecto, desde donde lo lances
# WORKSPACE=/ruta/al/proyecto
